generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model bouquet {
  id        Int     @id @default(autoincrement())
  nama      String
  harga     Int
  stok      Int
  deskripsi String?
}

model Order {
  id            Int    @id @default(autoincrement())
  namaPelanggan String
  totalHarga  Int
  status  String  @default("PENDING")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique  
  name      String
  password  String
  createdAt DateTime @default(now())  
  updatedAt DateTime @updatedAt
}